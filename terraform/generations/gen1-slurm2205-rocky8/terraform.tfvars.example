# =============================================================================
# terraform.tfvars.example — BurstLab Gen 1
# =============================================================================
# Copy this file to terraform.tfvars and fill in the required values:
#   cp terraform.tfvars.example terraform.tfvars
#
# Required values (no defaults):
#   key_name      — your EC2 key pair name
#   head_node_ami — AMI built by Packer (see below)
#
# Optional overrides are shown commented out with their defaults.
# =============================================================================

# AWS configuration
aws_region  = "us-west-2"
aws_profile = "aws"

# Cluster name — used as a prefix for all resource names.
# Change this if you want to run multiple BurstLab environments side-by-side.
cluster_name = "burstlab-gen1"

# SSH key pair name (REQUIRED — no default)
# Must already exist in your AWS account in the target region.
# Create with: aws ec2 create-key-pair --key-name burstlab --query 'KeyMaterial' --output text > ~/.ssh/burstlab.pem
key_name = "your-key-pair-name"

# Head node AMI (REQUIRED — no default)
# Output of: packer build ami/rocky8-slurm2205.pkr.hcl
# Get the latest AMI ID after a Packer build:
#   aws ec2 describe-images --owners self \
#     --filters 'Name=name,Values=burstlab-rocky8-slurm2205-*' \
#     --query 'sort_by(Images, &CreationDate)[-1].ImageId' \
#     --output text
head_node_ami = "ami-XXXXXXXX"

# Instance types (optional — defaults shown)
# head_node_instance_type    = "m7a.large"
# compute_node_instance_type = "m7a.large"
# burst_node_instance_type   = "m7a.xlarge"

# Cluster size (optional — defaults shown)
# compute_node_count = 4   # Number of always-on "on-prem" nodes
# max_burst_nodes    = 10  # Max concurrent burst nodes (cost safety limit)
