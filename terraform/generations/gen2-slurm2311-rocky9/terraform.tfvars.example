# =============================================================================
# terraform.tfvars.example — BurstLab Gen 2 (Rocky 9 + Slurm 23.11)
# =============================================================================
# Copy to terraform.tfvars and fill in the required values:
#   cp terraform.tfvars.example terraform.tfvars
#
# Required values (no defaults):
#   key_name      — your EC2 key pair name
#   head_node_ami — AMI built by Packer (see below)
# =============================================================================

# AWS configuration
aws_region  = "us-west-2"
aws_profile = "aws"

# Cluster name — distinguishes Gen 2 from Gen 1 and Gen 3 in the same account.
cluster_name = "burstlab-gen2"

# SSH key pair name (REQUIRED)
key_name = "your-key-pair-name"

# Head node AMI (REQUIRED)
# Build with: AWS_PROFILE=aws packer build ami/rocky9-slurm2311.pkr.hcl
# Get the latest built AMI:
#   AWS_PROFILE=aws aws ec2 describe-images --owners self \
#     --filters 'Name=name,Values=burstlab-gen2-*' \
#     --query 'sort_by(Images, &CreationDate)[-1].{ID:ImageId,Name:Name}' \
#     --output table
head_node_ami = "ami-XXXXXXXX"

# Instance types (optional — defaults shown)
# head_node_instance_type    = "m7a.2xlarge"
# compute_node_instance_type = "m7a.2xlarge"
# burst_node_instance_type   = "m7a.2xlarge"

# Cluster size (optional — defaults shown)
# compute_node_count = 4
# max_burst_nodes    = 10
