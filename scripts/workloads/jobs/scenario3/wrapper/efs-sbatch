#!/bin/bash
# =============================================================================
# efs-sbatch — Transparent EFS lifecycle wrapper for sbatch
#
# Install to /opt/slurm/bin/efs-sbatch.
# Real sbatch is at /opt/slurm-baked/bin/sbatch.
#
# Usage (identical to sbatch):
#   efs-sbatch myjob.sh
#
# The job script signals that it wants ephemeral EFS storage via:
#   #SBATCH --comment=efs
#
# What this wrapper does:
#   1. Parses the job script for #SBATCH --comment=efs
#   2. Creates an ephemeral EFS filesystem (~60 seconds, inline here)
#   3. Submits the real job with EFS_STATE_FILE injected into --export
#   4. Submits a destroy job (--partition=local, afterok:<workload_job_id>)
#   5. Returns the workload job ID (destroy is invisible to the user)
#
# SA talking point: "EFS is created right here — it's just an API call.
# The mount target goes into the cloud burst subnet. Once available (~60s),
# the job is submitted with the filesystem ID in its environment. The user
# typed one command and got one job ID back."
#
# Required env vars:
#   BURST_SUBNET_ID  — cloud burst subnet for EFS mount target
#   EFS_SG_ID        — security group (allows NFS from VPC)
#   AWS_REGION       — AWS region
# =============================================================================

set -euo pipefail

REAL_SBATCH=/opt/slurm-baked/bin/sbatch
LIB=/opt/slurm/etc/workloads/lib/efs-lifecycle.sh
DESTROY_SCRIPT=/opt/slurm/etc/workloads/jobs/scenario3/job3-destroy-efs.sh

# Find the job script (last non-option argument)
JOB_SCRIPT=""
for arg in "$@"; do
  if [[ "$arg" != -* ]] && [[ -f "$arg" ]]; then
    JOB_SCRIPT="$arg"
  fi
done

if [ -z "$JOB_SCRIPT" ]; then
  echo "efs-sbatch: no job script found in arguments — falling through to sbatch" >&2
  exec "$REAL_SBATCH" "$@"
fi

# ---------------------------------------------------------------------------
# Check for #SBATCH --comment=efs in the job script
# ---------------------------------------------------------------------------
if ! grep -q '^#SBATCH[[:space:]]\+--comment=efs' "$JOB_SCRIPT" 2>/dev/null; then
  exec "$REAL_SBATCH" "$@"
fi

# ---------------------------------------------------------------------------
# Source cluster config (set by Terraform — provides infrastructure vars)
# ---------------------------------------------------------------------------
if [ -f /etc/sysconfig/burstlab-workloads ]; then
  # shellcheck source=/dev/null
  source /etc/sysconfig/burstlab-workloads
fi

# ---------------------------------------------------------------------------
# Validate required env vars
# ---------------------------------------------------------------------------
: "${BURST_SUBNET_ID:?BURST_SUBNET_ID must be set — is the workloads overlay deployed?}"
: "${EFS_SG_ID:?EFS_SG_ID must be set — is the workloads overlay deployed?}"
: "${AWS_REGION:?AWS_REGION must be set}"

export AWS_REGION BURST_SUBNET_ID EFS_SG_ID

# ---------------------------------------------------------------------------
# Create EFS filesystem (inline — ~60 seconds)
# ---------------------------------------------------------------------------
echo "efs-sbatch: creating ephemeral EFS filesystem..." >&2

source "$LIB"

GRANULARITY="${GRANULARITY:-per-job}"
CAMPAIGN_NAME="${CAMPAIGN_NAME:-default}"
JOB_REF="wrap-$(date +%s)"
export GRANULARITY CAMPAIGN_NAME JOB_REF

EFS_ID=$(efs_create "${JOB_REF}")
efs_wait_available "${EFS_ID}"

# Create mount targets in BOTH cloud subnets (a and b).
# EFS DNS is AZ-specific: it only resolves to the mount target in the SAME
# AZ as the client. Burst nodes can land in either us-west-2a (cloud_a) or
# us-west-2b (cloud_b) via the EC2 Fleet. Without mount targets in both,
# burst nodes in the "wrong" AZ get "Name or service not known".
efs_add_mount_target "${EFS_ID}" "${BURST_SUBNET_ID}" "${EFS_SG_ID}"
if [ -n "${CLOUD_SUBNET_A_ID:-}" ] && [ "${CLOUD_SUBNET_A_ID}" != "${BURST_SUBNET_ID}" ]; then
  efs_add_mount_target "${EFS_ID}" "${CLOUD_SUBNET_A_ID}" "${EFS_SG_ID}"
fi
efs_wait_mount_target "${EFS_ID}"

# DNS propagation: AWS documents up to 90s for EFS mount target DNS to
# resolve after the mount target reaches 'available' state. Without this
# wait, jobs that start quickly on pre-warmed burst nodes fail with
# "Name or service not known" because DNS hasn't propagated yet.
echo "efs-sbatch: waiting 90s for EFS DNS to propagate..." >&2
sleep 90
EFS_DNS="${EFS_ID}.efs.${AWS_REGION}.amazonaws.com"

# Write state file
STATE_DIR="${HOME}/.efs-state"
mkdir -p "${STATE_DIR}"
STATE_FILE="${STATE_DIR}/job-${JOB_REF}.env"
cat > "${STATE_FILE}" << EOF
EFS_ID=${EFS_ID}
EFS_DNS=${EFS_DNS}
AWS_REGION=${AWS_REGION}
BURST_SUBNET_ID=${BURST_SUBNET_ID}
EFS_SG_ID=${EFS_SG_ID}
CREATED_BY_JOB=${JOB_REF}
GRANULARITY=${GRANULARITY}
CAMPAIGN_NAME=${CAMPAIGN_NAME}
EOF

echo "efs-sbatch: EFS ${EFS_ID} is available — submitting job..." >&2

# ---------------------------------------------------------------------------
# Build --export string
# ---------------------------------------------------------------------------
EXISTING_EXPORT=""
PASSTHROUGH_ARGS=()
for arg in "$@"; do
  if [[ "$arg" =~ ^--export=(.+)$ ]]; then
    EXISTING_EXPORT="${BASH_REMATCH[1]}"
  else
    PASSTHROUGH_ARGS+=("$arg")
  fi
done

EFS_ENV="EFS_STATE_FILE=${STATE_FILE},GRANULARITY=${GRANULARITY},CAMPAIGN_NAME=${CAMPAIGN_NAME},AWS_REGION=${AWS_REGION}"
if [ -n "$EXISTING_EXPORT" ]; then
  EXPORT_ARG="--export=${EXISTING_EXPORT},${EFS_ENV}"
else
  EXPORT_ARG="--export=ALL,${EFS_ENV}"
fi

# ---------------------------------------------------------------------------
# Submit workload job
# ---------------------------------------------------------------------------
# IMPORTANT: --export must come BEFORE the script path.
WORKLOAD_JOB_ID=$("$REAL_SBATCH" --parsable "$EXPORT_ARG" "${PASSTHROUGH_ARGS[@]}")
echo "efs-sbatch: workload job submitted: ${WORKLOAD_JOB_ID}" >&2

# ---------------------------------------------------------------------------
# Submit destroy job (local partition, invisible to user)
# ---------------------------------------------------------------------------
DESTROY_EXPORT="ALL,EFS_STATE_FILE=${STATE_FILE},GRANULARITY=${GRANULARITY},CAMPAIGN_NAME=${CAMPAIGN_NAME},AWS_REGION=${AWS_REGION}"
DESTROY_JOB_ID=$("$REAL_SBATCH" --parsable \
  --job-name=efs-destroy \
  --partition=local \
  --nodes=1 --ntasks=1 \
  --time=00:10:00 \
  --dependency=afterok:"${WORKLOAD_JOB_ID}" \
  --export="${DESTROY_EXPORT}" \
  "$DESTROY_SCRIPT")
echo "efs-sbatch: destroy job queued: ${DESTROY_JOB_ID} (afterok:${WORKLOAD_JOB_ID})" >&2

echo "${WORKLOAD_JOB_ID}"
